---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFrame from "../components/SiteFrame.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout
  title="Canopryx | On-Premises Security Infrastructure"
  description="Canopryx builds air-gap capable, zero-knowledge security infrastructure for organizations that require full control over credentials, secrets, and sensitive data."
>
  <SiteFrame>
    <main>
      <Hero />
    </main>
  </SiteFrame>

  <SiteFooter noMargin={true} />

  <div class="early-access-success" id="early-access-success" hidden>
    <div class="early-access-success__backdrop" data-success-close></div>
    <section class="early-access-success__card" role="dialog" aria-modal="true" aria-labelledby="early-access-success-title" tabindex="-1">
      <button class="early-access-success__close" type="button" aria-label="Close confirmation" data-success-close>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </button>
      <div class="early-access-success__mark" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="m5 12 4 4L19 6"/></svg>
      </div>
      <p class="early-access-success__eyebrow">Request received</p>
      <h2 id="early-access-success-title">Thank you for raising your hand.</h2>
      <p>We’ll review your environment and get back to you if Canopryx is a strong fit.</p>
      <button class="early-access-success__button" type="button" data-success-close>Back to Canopryx</button>
    </section>
  </div>
</BaseLayout>

<style>
  .early-access-success {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: grid;
    place-items: center;
    padding: 1.25rem;
  }

  .early-access-success[hidden] { display: none; }

  .early-access-success__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(11, 18, 22, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    animation: success-fade 0.25s ease-out;
  }

  .early-access-success__card {
    position: relative;
    width: min(100%, 28rem);
    padding: 2.5rem;
    overflow: hidden;
    text-align: center;
    background: var(--frame-shell);
    border: 1px solid rgba(191, 196, 204, 0.12);
    border-radius: 1.5rem;
    box-shadow: 0 32px 64px rgba(0, 0, 0, 0.5);
    animation: success-rise 0.35s var(--ease-smooth);
  }

  .early-access-success__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: grid;
    width: 2.2rem;
    height: 2.2rem;
    place-items: center;
    color: var(--frame-graphite);
    background: transparent;
    border: 0;
    border-radius: 50%;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }

  .early-access-success__close:hover {
    color: var(--frame-text);
    background: var(--frame-seam);
  }

  .early-access-success__close svg { width: 1rem; fill: none; stroke: currentColor; stroke-width: 2; }

  .early-access-success__mark {
    display: grid;
    width: 3.5rem;
    height: 3.5rem;
    margin: 0 auto 1.25rem;
    place-items: center;
    color: #72ca94;
    background: rgba(56, 161, 105, 0.12);
    border: 1px solid rgba(114, 202, 148, 0.2);
    border-radius: 1rem;
  }

  .early-access-success__mark svg { width: 1.5rem; fill: none; stroke: currentColor; stroke-width: 2; }
  .early-access-success__eyebrow { margin-bottom: 0.5rem; font: 600 0.75rem/1 var(--font-display); letter-spacing: 0.12em; text-transform: uppercase; color: #72ca94; }
  .early-access-success h2 { font-size: clamp(1.4rem, 4vw, 1.75rem); line-height: 1.2; letter-spacing: -0.02em; color: var(--frame-text); }
  .early-access-success p:not(.early-access-success__eyebrow) { max-width: 22rem; margin: 0.75rem auto 0; font-size: 0.95rem; line-height: 1.6; color: var(--frame-graphite); }
  
  .early-access-success__button { 
    margin-top: 1.75rem; 
    padding: 0.75rem 1.5rem; 
    font: 600 0.8rem/1 var(--font-display); 
    letter-spacing: 0.1em; 
    text-transform: uppercase; 
    color: var(--frame-text); 
    background: var(--frame-seam); 
    border: 1px solid rgba(191, 196, 204, 0.1); 
    border-radius: var(--radius-pill); 
    cursor: pointer; 
    transition: background 0.15s, color 0.15s;
  }
  .early-access-success__button:hover {
    background: #72ca94;
    color: #0b1216;
  }

  @keyframes success-fade { from { opacity: 0; } }
  @keyframes success-rise { from { opacity: 0; transform: translateY(16px) scale(0.98); } }

  @media (max-width: 540px) {
    .early-access-success__card { padding: 2.25rem 1.5rem; border-radius: 1.25rem; }
  }
</style>

<script>
  function initEarlyAccessSuccess() {
    const modal = document.getElementById('early-access-success');
    if (!(modal instanceof HTMLElement) || modal.dataset.initialized === 'true') return;
    modal.dataset.initialized = 'true';

    const url = new URL(window.location.href);
    if (url.searchParams.get('early-access') !== 'received') return;

    url.searchParams.delete('early-access');
    window.history.replaceState({}, '', `${url.pathname}${url.search}${url.hash}`);

    const card = modal.querySelector<HTMLElement>('.early-access-success__card');
    const previousFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    const close = () => {
      modal.hidden = true;
      document.body.style.overflow = '';
      previousFocus?.focus();
    };

    modal.querySelectorAll('[data-success-close]').forEach((element) => element.addEventListener('click', close));
    modal.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') close();
    });

    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    card?.focus();
  }

  initEarlyAccessSuccess();
  document.addEventListener('astro:page-load', initEarlyAccessSuccess);
</script>
