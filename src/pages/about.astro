---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ValueCard from "../components/ValueCard.astro";
import ScrollReveal from "../components/ScrollReveal.astro";

const values = [
  {
    title: "Focused",
    description: "We build focused security products with a cleaner public surface.",
  },
  {
    title: "Deliberate",
    description: "What is public is intentional. What is not ready stays private.",
  },
  {
    title: "Practical",
    description: "The goal is clarity, not noise.",
  },
];
---

<BaseLayout
  title="About - Olvara Labs"
  description="Learn about Olvara Labs - building modern cybersecurity tools with a cleaner and more deliberate public presence."
>
  <SiteHeader />

  <main>
    <section class="about page-shell" style="padding-top: 9rem; padding-bottom: 4rem;">
      <div class="about__header">

        <h1 class="about__title enter-after-nav" style="--enter-delay: 0.5s;">About Olvara Labs</h1>
        <p class="about__subtitle enter-after-nav" style="--enter-delay: 0.58s;">
          Building modern cybersecurity tools with a cleaner and more deliberate public&nbsp;presence.
        </p>
      </div>

      <div class="about__grid">
        {values.map((value, i) => (
          <ValueCard
            title={value.title}
            description={value.description}
            index={i}
          />
        ))}
      </div>
    </section>
  </main>

  <SiteFooter />
  <ScrollReveal />
</BaseLayout>
