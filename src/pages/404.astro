---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Page Not Found - Olvara Labs"
  description="The page you are looking for does not exist."
>
  <SiteHeader />

  <main>
    <section class="not-found page-shell">
      <div class="not-found__content enter-after-nav" style="--enter-delay: 0.3s;">
        <h1 class="not-found__title">404</h1>
        <p class="not-found__subtitle">
          The page you are looking for has either been moved, deleted, or never existed in the first place.
        </p>
        <a class="btn-primary" href="/" style="margin-top: 2rem;">
          Return Home
        </a>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: 6rem;
  }
  .not-found__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 32rem;
  }
  .not-found__title {
    font-size: clamp(6rem, 15vw, 10rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-primary);
    text-shadow: 0 0 40px rgba(29, 124, 73, 0.2);
    margin-bottom: 1rem;
  }
  .not-found__subtitle {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text-muted);
  }
</style>
