---
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ScrollReveal from "../components/ScrollReveal.astro";

const { frontmatter } = Astro.props;
---

<BaseLayout
  title={`${frontmatter.title} - Olvara Labs`}
  description={frontmatter.description || `Olvara Labs ${frontmatter.title}`}
>
  <SiteHeader />

  <main>
    <section class="legal page-shell" style="padding-top: 9rem; padding-bottom: 4rem;">
      <div class="legal__header">
        <h1 class="legal__title enter-after-nav" style="--enter-delay: 0.5s;">{frontmatter.title}</h1>
      </div>
      <div class="legal__content enter-after-nav" style="--enter-delay: 0.58s;">
        <slot />
      </div>
    </section>
  </main>

  <SiteFooter />
  <ScrollReveal />
</BaseLayout>

<style is:global>
  .legal {
    max-width: 800px;
    margin: 0 auto;
    padding-inline: 1.5rem;
  }
  
  .legal__title {
    font-size: var(--fs-4xl);
    letter-spacing: -0.03em;
    font-weight: 500;
    margin-bottom: 2.5rem;
    color: var(--color-foreground);
  }

  .legal__content {
    color: var(--color-secondary);
    line-height: 1.7;
    font-size: 1.05rem;
  }

  .legal__content h2 {
    color: var(--color-foreground);
    font-size: var(--fs-2xl);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  
  .legal__content h3 {
    color: var(--color-foreground);
    font-size: var(--fs-xl);
    font-weight: 500;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .legal__content p {
    margin-bottom: 1.5rem;
  }

  .legal__content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .legal__content li {
    margin-bottom: 0.5rem;
  }

  .legal__content a {
    color: var(--color-foreground);
    text-decoration: underline;
    text-decoration-color: var(--color-border);
    text-underline-offset: 4px;
    transition: text-decoration-color 0.2s ease;
  }

  .legal__content a:hover {
    text-decoration-color: var(--color-foreground);
  }

  .legal__content strong {
    color: var(--color-foreground);
    font-weight: 500;
  }
</style>
